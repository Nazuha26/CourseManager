<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="300.0" styleClass="window" stylesheets="@../dialog_ui.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.dialogs.password.GeneratedPass_controller">

    <top>
        <HBox alignment="CENTER_RIGHT" onMouseDragged="#onTitleBarDragged" onMousePressed="#onTitleBarPressed" styleClass="title-bar" stylesheets="@../../styles/title_bar_style.css" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="window-app-name" text="Password">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnClose" onAction="#btnClose" prefHeight="30.0" prefWidth="30.0" styleClass="window-button-close" />
            </children>
            <padding>
                <Insets left="10.0" />
            </padding>
        </HBox>
    </top>

    <bottom>
      <VBox alignment="CENTER" BorderPane.alignment="CENTER">
         <children>
              <HBox alignment="CENTER" spacing="10">
                  <children>
                  <VBox>
                     <children>
                        <Label text="Password:" textFill="#dddddd" />
                        <Label fx:id="lblPassword" text="123456789#" textFill="#dddddd">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                      <Button fx:id="btnCopy" onAction="#btnCopy" styleClass="button-confirm" text="Copy" />
                  </children>
                  <padding>
                      <Insets bottom="10" top="10" />
                  </padding>
              </HBox>
            <Label fx:id="lblCopied" alignment="CENTER" contentDisplay="CENTER" managed="false" text="Successfully copied" textFill="#00bc3c">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
         </children>
      </VBox>
    </bottom>
    <center>
        <HBox alignment="CENTER" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Save password" textFill="#dddddd">
                            <font>
                                <Font name="System Bold" size="17.0" />
                            </font>
                        </Label>
                        <Label layoutX="149.0" layoutY="25.0" text="A password has been generated &#10;for the course, please save it to &#10;avoid losing access to the course." textFill="#dddddd">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
            <BorderPane.margin>
                <Insets />
            </BorderPane.margin>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </HBox>
    </center>
</BorderPane>
