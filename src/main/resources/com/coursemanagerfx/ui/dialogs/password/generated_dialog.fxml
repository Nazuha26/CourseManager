<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="540.0" styleClass="window" stylesheets="@../dialog_ui.css" xmlns="http://javafx.com/javafx/23.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.controllers.dialogs.password.GeneratedPass_controller">

    <top>
        <HBox fx:id="titleBar" alignment="CENTER_RIGHT" styleClass="title-bar" stylesheets="@../../styles/title_bar_style.css" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="10.0" />
            </padding>
            <Label styleClass="window-app-name" text="Course seed phrase">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnClose" onAction="#btnClose" prefHeight="30.0" prefWidth="30.0" styleClass="window-button-close" />
        </HBox>
    </top>

    <bottom>
        <VBox alignment="CENTER" spacing="5.0" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER" spacing="10">
                <VBox>
                    <Label text="Seed phrase:" textFill="#dddddd" />
                    <Label fx:id="lblPassword" maxWidth="430.0" text="word word word word word" textFill="#dddddd" wrapText="true">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                </VBox>
                <Button fx:id="btnCopy" onAction="#btnCopy" styleClass="button-default" text="Copy" />
            </HBox>
            <Label fx:id="lblCopied" alignment="CENTER" contentDisplay="CENTER" managed="false" text="Successfully copied" textFill="#00bc3c">
                <font>
                    <Font name="System Bold" size="15.0" />
                </font>
            <VBox.margin>
               <Insets />
            </VBox.margin>
            </Label>
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
        </VBox>
    </bottom>
    <center>
        <HBox alignment="CENTER" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets />
            </BorderPane.margin>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Save this seed phrase" textFill="#dddddd">
                    <font>
                        <Font name="System Bold" size="17.0" />
                    </font>
                </Label>
                <Label alignment="CENTER" layoutX="149.0" layoutY="25.0" text="Five random words protect this course. Copy and store them safely.&#10;Without this phrase the course cannot be opened or recovered." textAlignment="JUSTIFY" textFill="#dddddd" wrapText="true">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </VBox>
        </HBox>
    </center>
</BorderPane>
