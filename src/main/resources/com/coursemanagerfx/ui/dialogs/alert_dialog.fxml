<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="350.0" styleClass="window" stylesheets="@dialog_ui.css" xmlns="http://javafx.com/javafx/23.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.controllers.dialogs.alert.AlertFX_controller">

<top>
    <HBox fx:id="titleBar" alignment="CENTER_RIGHT" styleClass="title-bar" stylesheets="@../styles/title_bar_style.css" BorderPane.alignment="CENTER">
        <padding>
            <Insets left="10.0" />
        </padding>
        <Label fx:id="labelTitle" styleClass="window-app-name" text="Alert dialog">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnClose" onAction="#btnClose" prefHeight="30.0" prefWidth="30.0" styleClass="window-button-close" />
    </HBox>
</top>

<bottom>
    <HBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
        <padding>
            <Insets bottom="10" top="10" />
        </padding>
        <Button fx:id="btnConfirm" onAction="#btnConfirm" styleClass="button-cancel" text="OK" />
        <Button fx:id="btnCancel" onAction="#btnCancel" styleClass="button-default" text="Cancel" />
    </HBox>
</bottom>
<center>
    <HBox alignment="CENTER" BorderPane.alignment="CENTER">
        <BorderPane.margin>
            <Insets />
        </BorderPane.margin>
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <ImageView fx:id="iconType" fitHeight="64.0" fitWidth="64.0" pickOnBounds="true" preserveRatio="true" HBox.hgrow="ALWAYS">
            <HBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </HBox.margin>
            <Image url="@../notifications/icons/warning_256x256.png" />
        </ImageView>
        <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
            <Label fx:id="labelMain" maxWidth="300" text="Main text" textFill="#dddddd" wrapText="true">
                <font>
                    <Font name="System Bold" size="17.0" />
                </font>
            </Label>
            <Label fx:id="labelPrompt" maxWidth="300" text="Some text here. It is just a text to make this sentence long something about 40 words." textFill="#dddddd" wrapText="true">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
        </VBox>
    </HBox>
</center>
</BorderPane>
