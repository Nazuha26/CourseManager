<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="350.0" styleClass="window" stylesheets="@dialog_ui.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.dialogs.alert.AlertFX_controller">

<top>
    <HBox fx:id="titleBar" alignment="CENTER_RIGHT" onMouseDragged="#onTitleBarDragged" onMousePressed="#onTitleBarPressed" styleClass="title-bar" stylesheets="@../styles/title_bar_style.css" BorderPane.alignment="CENTER">
        <children>
            <Label fx:id="labelTitle" styleClass="window-app-name" text="Confirmation">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnClose" onAction="#btnClose" prefHeight="30.0" prefWidth="30.0" styleClass="window-button-close" />
        </children>
        <padding>
            <Insets left="10.0" />
        </padding>
    </HBox>
</top>

<bottom>
    <HBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
        <children>
            <Button fx:id="btnConfirm" onAction="#btnConfirm" styleClass="button-confirm" text="OK" />
            <Button fx:id="btnCancel" onAction="#btnCancel" styleClass="button-cancel" text="Cancel" />
        </children>
        <padding>
            <Insets bottom="10" top="10" />
        </padding>
    </HBox>
</bottom>
<center>
    <HBox alignment="CENTER" BorderPane.alignment="CENTER">
        <children>
            <ImageView fx:id="iconType" fitHeight="64.0" fitWidth="64.0" pickOnBounds="true" preserveRatio="true" HBox.hgrow="ALWAYS">
                <image>
                    <Image url="@../notifications/icons/warning_256x256.png" />
                </image>
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </HBox.margin>
            </ImageView>
            <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                <children>
                    <Label fx:id="labelMain" text="Main text" textFill="#dddddd">
                        <font>
                            <Font name="System Bold" size="17.0" />
                        </font>
                    </Label>
                    <Label fx:id="labelPrompt" layoutX="149.0" layoutY="25.0" text="Some text here. It just a text &#10;to make this sentence long &#10;something about 40 words." textFill="#dddddd">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </children>
            </VBox>
        </children>
        <BorderPane.margin>
            <Insets />
        </BorderPane.margin>
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
    </HBox>
</center>
</BorderPane>
