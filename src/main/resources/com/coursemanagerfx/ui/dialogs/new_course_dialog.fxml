<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="300.0" styleClass="window" stylesheets="@dialog_ui.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.controllers.dialogs.NewCourseDialog_controller">

    <top>
        <HBox fx:id="titleBar" alignment="CENTER_RIGHT" styleClass="title-bar" stylesheets="@../styles/title_bar_style.css" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="window-app-name" text="Creating the new course">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnClose" onAction="#btnClose" prefHeight="30.0" prefWidth="30.0" styleClass="window-button-close" />
            </children>
            <padding>
                <Insets left="10.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
            <children>
            <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                      <Label text="Course number:" textFill="#dddddd">
                          <font>
                              <Font size="14.0" />
                          </font>
                  </Label>
                  <Spinner fx:id="spinCourseNumber" prefWidth="70.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Groups count:" textFill="#dddddd">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <Spinner fx:id="spinGroupsCount" prefWidth="70.0" />
               </children>
            </HBox>
                <Label fx:id="errorLabel" managed="false" text="Error label" textFill="#cc0000">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets left="15.0" right="15.0" top="15.0" />
            </padding>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnConfirm" onAction="#btnConfirm" styleClass="button-confirm" text="OK" />
                <Button fx:id="btnCancel" onAction="#btnCancel" styleClass="button-cancel" text="Cancel" />
            </children>
            <padding>
                <Insets bottom="10" top="10" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>
