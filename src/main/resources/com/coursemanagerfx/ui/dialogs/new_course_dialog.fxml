<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="300.0" styleClass="window" stylesheets="@dialog_ui.css" xmlns="http://javafx.com/javafx/23.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.controllers.dialogs.NewCourseDialog_controller">

    <top>
        <HBox fx:id="titleBar" alignment="CENTER_RIGHT" styleClass="title-bar" stylesheets="@../styles/title_bar_style.css" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="10.0" />
            </padding>
            <Label styleClass="window-app-name" text="Creating the new course">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnClose" onAction="#btnClose" prefHeight="30.0" prefWidth="30.0" styleClass="window-button-close" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                <Label text="Course number:" textFill="#dddddd">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Spinner fx:id="spinCourseNumber" prefWidth="70.0" />
            </HBox>
            <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                <Label text="Groups count:" textFill="#dddddd">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Spinner fx:id="spinGroupsCount" prefWidth="70.0" />
            </HBox>
            <Label fx:id="errorLabel" managed="false" text="Error label" textFill="#cc0000">
                <font>
                    <Font name="System Bold" size="15.0" />
                </font>
            </Label>
           <HBox alignment="CENTER" spacing="10">
               <Button fx:id="btnConfirm" onAction="#btnConfirm" styleClass="button-default" text="OK" />
               <Button fx:id="btnCancel" onAction="#btnCancel" styleClass="button-cancel" text="Cancel" />
           </HBox>
         <BorderPane.margin>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </BorderPane.margin>
        </VBox>
    </center>
</BorderPane>
