<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.input.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.fxmisc.flowless.*?>
<?import org.fxmisc.richtext.*?>

<BorderPane id="mainPanel" fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" stylesheets="@../styles/main_style.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.controllers.main.Main_controller">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <BorderPane fx:id="titleBar" styleClass="title-bar" stylesheets="@../styles/title_bar_style.css">
            <center>
               <Label fx:id="lblAppName" styleClass="window-app-name" text="CourseManagerFX" BorderPane.alignment="CENTER">
                  <font>
                     <Font size="15.0" />
                  </font>
               </Label>
            </center>
            <left>
               <HBox alignment="CENTER" spacing="5.0" BorderPane.alignment="CENTER">
                  <MenuBar styleClass="menu-bar-root" stylesheets="@../styles/menu_bar.css">
                     <Menu mnemonicParsing="false" text="File">
                        <MenuItem fx:id="miHome" mnemonicParsing="false" onAction="#miHome" styleClass="menu-bar-item" text="Home" />
                        <MenuItem fx:id="miSave" mnemonicParsing="false" onAction="#miSave" styleClass="menu-bar-item" text="Save">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="S" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                        <MenuItem fx:id="miExport" mnemonicParsing="false" onAction="#miExport" styleClass="menu-bar-item" text="Export">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="E" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                        <SeparatorMenuItem mnemonicParsing="false" styleClass="menu-bar-separator" />
                        <MenuItem fx:id="miQuit" mnemonicParsing="false" onAction="#miQuit" styleClass="menu-bar-item-quit" text="Quit">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="Q" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                     </Menu>
                     <Menu mnemonicParsing="false" text="Edit">
                        <MenuItem fx:id="miUndo" disable="true" mnemonicParsing="false" onAction="#miUndo" styleClass="menu-bar-item" text="Undo">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="Z" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                        <MenuItem fx:id="miRedo" disable="true" mnemonicParsing="false" onAction="#miRedo" styleClass="menu-bar-item" text="Redo">
                           <accelerator>
                              <KeyCodeCombination alt="UP" code="Z" control="DOWN" meta="UP" shift="DOWN" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                        <SeparatorMenuItem mnemonicParsing="false" styleClass="menu-bar-separator" />
                        <MenuItem mnemonicParsing="false" onAction="#miOptions" styleClass="menu-bar-item" text="Options">
                           <accelerator>
                              <KeyCodeCombination alt="DOWN" code="O" control="UP" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                     </Menu>
                     <Menu mnemonicParsing="false" text="Help">
                        <MenuItem mnemonicParsing="false" onAction="#miAbout" styleClass="menu-bar-item" text="About">
                           <accelerator>
                              <KeyCodeCombination alt="DOWN" code="A" control="UP" meta="UP" shift="UP" shortcut="UP" />
                           </accelerator>
                        </MenuItem>
                     </Menu>
                  </MenuBar>

                  <Button contentDisplay="RIGHT" graphicTextGap="10.0" mnemonicParsing="false" onAction="#miExport" prefWidth="100.0" styleClass="export-button" text="Export">
                     <tooltip>
                        <Tooltip text="Export data to excel file" />
                     </tooltip>
                     <graphic>
                        <ImageView fitHeight="24" fitWidth="24">
                           <Image url="@../icons/w_export_256x256.png" />
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="14.0" />
                     </font>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </Button>
                  <Region prefWidth="20.0" />
                  <Button fx:id="btnUndo" disable="true" mnemonicParsing="false" onAction="#miUndo" prefHeight="32.0" prefWidth="32.0" styleClass="undo-button">
                     <tooltip>
                        <Tooltip text="Undo last action" />
                     </tooltip>
                  </Button>
                  <Button fx:id="btnRedo" disable="true" mnemonicParsing="false" onAction="#miRedo" prefHeight="32.0" prefWidth="32.0" styleClass="redo-button">
                     <tooltip>
                        <Tooltip text="Redo last action" />
                     </tooltip>
                  </Button>

               </HBox>
            </left>
            <right>
               <HBox alignment="CENTER_LEFT" nodeOrientation="RIGHT_TO_LEFT" BorderPane.alignment="CENTER">
                  <Button fx:id="btnClose" layoutX="10.0" layoutY="10.0" onAction="#windowClose" prefHeight="40.0" prefWidth="40.0" styleClass="window-button-close" />
                  <Button fx:id="btnMinimize" onAction="#windowMinimize" prefHeight="40.0" prefWidth="40.0" styleClass="window-button-minimize" />
               </HBox>
            </right>
         </BorderPane>
         <HBox fx:id="tabHBox" spacing="5.0" styleClass="hbox">
            <padding>
               <Insets left="5.0" right="5.0" top="5.0" />
            </padding>
         </HBox>
      </VBox>
   </top>
   <center>
      <StackPane BorderPane.alignment="CENTER">
         <Pane prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #00000066;" />
         <BorderPane>
            <left>
               <BorderPane styleClass="fancy-left-pane" BorderPane.alignment="CENTER">
                  <center>
                     <BorderPane styleClass="fancy-internal-left-pane">
                        <center>
                           <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefHeight="300.0">
                              <VBox fx:id="studentVBox" maxWidth="370.0" minWidth="370.0" prefWidth="370.0" />
                           </ScrollPane>
                        </center>
                     </BorderPane>
                  </center>
                  <top>
                     <BorderPane BorderPane.alignment="CENTER">
                        <center>
                           <Label fx:id="lblGroupNumber" alignment="CENTER" contentDisplay="CENTER" text="GROUP X" textFill="#dddddd" BorderPane.alignment="CENTER">
                              <font>
                                 <Font name="System Bold" size="16.0" />
                              </font>
                              <padding>
                                 <Insets left="20.0" right="20.0" />
                              </padding>
                           </Label>
                        </center>
                        <left>
                           <Button fx:id="btnAddStudent" mnemonicParsing="false" onAction="#btnAddStudent" prefHeight="35.0" prefWidth="35.0" styleClass="animated-add-student-button" BorderPane.alignment="CENTER" />
                        </left>
                        <BorderPane.margin>
                           <Insets />
                        </BorderPane.margin>
                        <padding>
                           <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                        </padding>
                        <right>
                           <TextField fx:id="txtFieldSearch" promptText="Search" styleClass="search-field" BorderPane.alignment="CENTER" />
                        </right>
                     </BorderPane>
                  </top>
                  <BorderPane.margin>
                     <Insets right="5.0" top="5.0" />
                  </BorderPane.margin>
               </BorderPane>
            </left>
            <center>
               <BorderPane prefHeight="300.0" prefWidth="500.0" BorderPane.alignment="CENTER">
                  <bottom>
                     <BorderPane BorderPane.alignment="CENTER">
                        <center>
                           <StackPane fx:id="infoTopPane" styleClass="fancy-pane" BorderPane.alignment="CENTER">
                              <BorderPane fx:id="eventInfoMaskPane" prefHeight="225.0" BorderPane.alignment="CENTER">
                                 <center>
                                    <StackPane BorderPane.alignment="CENTER">
                                       <BorderPane.margin>
                                          <Insets right="5.0" />
                                       </BorderPane.margin>
                                       <StackPane>
                                          <TextArea fx:id="txtAreaEventDescrp" wrapText="true" />
                                          <Label fx:id="placeholderLbl" mouseTransparent="true" styleClass="label-placeholder" text="Type your event description here...&#10;You can make text bold, italic or underlined&#10;by pressing the buttons below." wrapText="true" />
                                       </StackPane>
                                       <Button fx:id="btnCancelEvent" maxHeight="48.0" maxWidth="48.0" mnemonicParsing="false" onAction="#btnCancelEvent" styleClass="animated-back-button" StackPane.alignment="BOTTOM_LEFT">
                                          <StackPane.margin>
                                             <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                          </StackPane.margin>
                                       </Button>
                                       <Label fx:id="lblEditing" managed="false" opacity="0.4" text="Editing..." textFill="#dddddd" visible="false" StackPane.alignment="BOTTOM_CENTER">
                                          <font>
                                             <Font size="18.0" />
                                          </font>
                                          <StackPane.margin>
                                             <Insets bottom="10.0" />
                                          </StackPane.margin>
                                       </Label>
                                       <HBox alignment="BOTTOM_RIGHT" pickOnBounds="false" spacing="5.0">
                                          <StackPane.margin>
                                             <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                                          </StackPane.margin>
                                          <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
                                                minHeight="-Infinity" minWidth="-Infinity">
                                             <Button mnemonicParsing="false" onAction="#setBoldText" prefHeight="32.0"
                                                     prefWidth="32.0" styleClass="first-styled-button-bold" text="B">
                                                <font>
                                                   <Font name="System Bold" size="12.0"/>
                                                </font>
                                                <tooltip>
                                                   <Tooltip text="Makes the selected text bold" />
                                                </tooltip>
                                             </Button>
                                             <Button mnemonicParsing="false" onAction="#setItalicText" prefHeight="32.0"
                                                     prefWidth="32.0" styleClass="middle-styled-button-italic" text="I">
                                                <font>
                                                   <Font name="System Italic" size="12.0"/>
                                                </font>
                                                <tooltip>
                                                   <Tooltip text="Makes the selected text italic" />
                                                </tooltip>
                                             </Button>
                                             <Button mnemonicParsing="false" onAction="#setUnderlineText"
                                                     prefHeight="32.0" prefWidth="32.0"
                                                     styleClass="last-styled-button-underline" text="U"
                                                     underline="true">
                                                <tooltip>
                                                   <Tooltip text="Underlines the selected text" />
                                                </tooltip>
                                             </Button>
                                          </HBox>
                                          <Button mnemonicParsing="false" onAction="#btnClearEventInfo"
                                                  prefHeight="32.0" prefWidth="64.0" styleClass="clear-all-button"
                                                  text="clear">
                                             <tooltip>
                                                <Tooltip text="Clears all entered information in this panel" />
                                             </tooltip>
                                          </Button>
                                       </HBox>
                                    </StackPane>
                                 </center>
                                 <right>
                                    <VBox spacing="5.0" BorderPane.alignment="CENTER">
                                       <BorderPane VBox.vgrow="ALWAYS">
                                          <center>
                                             <!-- Растягивается на всю оставшуюся ширину -->
                                             <ComboBox fx:id="comBoxEventCategory" maxHeight="Infinity" maxWidth="Infinity" />
                                          </center>
                                          <top>
                                             <HBox BorderPane.alignment="CENTER">
                                                <Label text="Mode:" textFill="#dddddd">
                                                   <font>
                                                      <Font size="13.0" />
                                                   </font>
                                                   <HBox.margin>
                                                      <Insets left="10.0" />
                                                   </HBox.margin>
                                                </Label>
                                             </HBox>
                                          </top>
                                       </BorderPane>
                                       <HBox spacing="5.0" VBox.vgrow="ALWAYS">
                                          <VBox alignment="CENTER" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="200.0" spacing="5.0" HBox.hgrow="ALWAYS">
                                             <BorderPane maxHeight="-Infinity" prefHeight="70.0">
                                                <center>

                                                   <DatePicker fx:id="dtpkCreationDate" maxHeight="Infinity" maxWidth="1.7976931348623157E308" promptText="Creation date" BorderPane.alignment="CENTER" />
                                                </center>
                                                <top>
                                                   <Label minWidth="-Infinity" text="Creation date" textFill="#dddddd" BorderPane.alignment="CENTER">
                                                      <font>
                                                         <Font size="13.0" />
                                                      </font>
                                                   </Label>
                                                </top>
                                             </BorderPane>
                                             <BorderPane maxHeight="-Infinity" prefHeight="70.0">
                                                <center>


                                                   <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" BorderPane.alignment="CENTER">
                                                      <DatePicker fx:id="dtpkExpirationDate" managed="false" maxHeight="Infinity" maxWidth="1.7976931348623157E308" promptText="Expiration date" visible="false" HBox.hgrow="ALWAYS" />

                                                      <HBox fx:id="hboxExpiredTime" alignment="CENTER_LEFT" maxHeight="Infinity" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS">
                                                         <Spinner fx:id="spinnerExpTimeCount" editable="true" maxHeight="Infinity" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="70.0" styleClass="expired-spinner" HBox.hgrow="ALWAYS" />
                                                         <ComboBox fx:id="comBoxExpTimeType" maxHeight="Infinity" maxWidth="1.7976931348623157E308" styleClass="expired-combo-box" HBox.hgrow="ALWAYS">
                                                         </ComboBox>
                                                      </HBox>
                                                   </HBox>

                                                </center>
                                                <top>
                                                   <Label text="Expiration date" textFill="#dddddd" BorderPane.alignment="CENTER">
                                                      <font>
                                                         <Font size="13.0" />
                                                      </font>
                                                   </Label>
                                                </top>
                                             </BorderPane>
                                          </VBox>
                                          <VBox alignment="CENTER" prefWidth="80.0" spacing="5.0" HBox.hgrow="ALWAYS">
                                             <BorderPane maxHeight="-Infinity" prefHeight="70.0">
                                                <center>
                                                   <Spinner fx:id="spinnerMark" editable="true" maxHeight="Infinity" BorderPane.alignment="CENTER" />
                                                </center>
                                                <top>
                                                   <Label maxHeight="Infinity" minWidth="-Infinity" text="Mark" textFill="#dddddd" BorderPane.alignment="CENTER">
                                                      <font>
                                                         <Font size="13.0" />
                                                      </font>
                                                   </Label>
                                                </top>
                                             </BorderPane>
                                             <BorderPane maxHeight="-Infinity" prefHeight="70.0" VBox.vgrow="NEVER">
                                                <top>
                                                   <Label textFill="#dddddd" BorderPane.alignment="CENTER">
                                                      <font>
                                                         <Font size="13.0" />
                                                      </font>
                                                   </Label>
                                                </top>
                                                <center>
                                                   <Button fx:id="btnToSchedule" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="-Infinity" mnemonicParsing="false" onAction="#toggleExpirationInput" styleClass="animated-to-schedule-button" BorderPane.alignment="CENTER" />
                                                </center>
                                             </BorderPane>
                                          </VBox>
                                       </HBox>
                                       <HBox spacing="5.0" VBox.vgrow="ALWAYS">
                                          <Button fx:id="btnDeleteEvent" managed="false" maxHeight="Infinity" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="animated-cancel-button" text="Delete" visible="false" HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnCreateEvent" maxHeight="Infinity" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnCreateEvent" styleClass="animated-create-button" text="Create" HBox.hgrow="ALWAYS" />
                                       </HBox>
                                    </VBox>
                                 </right>
                              </BorderPane>

                              <!-- Панель истории (сначала скрыта) -->
                              <StackPane fx:id="historyInfoMaskPane" managed="false" visible="false">
                                 <BorderPane prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
                                    <center>
                                       <org.fxmisc.flowless.VirtualizedScrollPane prefHeight="200" prefWidth="400" xmlns:fx="http://javafx.com/fxml">
                                          <content>
                                             <org.fxmisc.richtext.InlineCssTextArea fx:id="richTxtPaneHistory" editable="false" styleClass="inline-css-text-area" wrapText="true" />
                                          </content>
                                       </org.fxmisc.flowless.VirtualizedScrollPane>
                                    </center>
                                 </BorderPane>

                                 <!-- BUTTON "BACK"-->
                                 <Button fx:id="btnBackFromHistory" onAction="#btnBackFromHistory" styleClass="animated-button" text="Back">
                                    <StackPane.margin>
                                       <Insets bottom="10" right="20" />
                                    </StackPane.margin>
                                    <StackPane.alignment>BOTTOM_RIGHT</StackPane.alignment>
                                 </Button>

                                 <!-- BUTTON "CLEAR HISTORY"-->
                                 <Button fx:id="btnClearHistory" onAction="#btnClearHistory" prefHeight="48" prefWidth="48" styleClass="animated-clear-history-button">

                                    <StackPane.margin>
                                       <Insets right="20" top="10" />
                                    </StackPane.margin>
                                    <StackPane.alignment>TOP_RIGHT</StackPane.alignment>
                                 </Button>
                              </StackPane>
                           </StackPane>
                        </center>
                        <bottom>
                           <HBox fx:id="infoBotPane" alignment="CENTER_LEFT" spacing="10" BorderPane.alignment="CENTER">
                              <Button fx:id="btnAddEvent" maxHeight="Infinity" onAction="#btnAddEvent" styleClass="animated-button" text="➕ Event" />

                              <StackPane styleClass="fancy-pane" HBox.hgrow="ALWAYS">
                                 <BorderPane>
                                    <right>
                                       <Button fx:id="btnOpenHistory" onAction="#btnHistory" styleClass="animated-button" text="History" />
                                    </right>
                                    <center>
                                       <BorderPane BorderPane.alignment="CENTER">
                                          <left>
                                             <Label text="SOME INFO TEXT" textFill="WHITE" BorderPane.alignment="CENTER">
                                                <font>
                                                   <Font size="16.0" />
                                                </font>
                                             </Label>
                                          </left>
                                          <right>
                                             <Label fx:id="lblCurHistory" alignment="CENTER" text="History info" textAlignment="RIGHT" textFill="WHITE" BorderPane.alignment="CENTER">
                                                <font>
                                                   <Font size="16.0" />
                                                </font>
                                             </Label>
                                          </right>
                                          <padding>
                                             <Insets left="10.0" right="10.0" />
                                          </padding>
                                       </BorderPane>
                                    </center>
                                 </BorderPane>
                              </StackPane>
                           </HBox>
                        </bottom>
                     </BorderPane>
                  </bottom>
                  <center>
                     <StackPane fx:id="tableStackPane" styleClass="fancy-pane" BorderPane.alignment="CENTER">
                        <BorderPane.margin>
                           <Insets bottom="10.0" />
                        </BorderPane.margin>
                        <TableView fx:id="eventsTable" stylesheets="@../styles/table.css">
                           <columns>
                              <TableColumn fx:id="numberColumn" editable="false" maxWidth="50.0" minWidth="50.0" prefWidth="50.0" resizable="false" text="№" />
                              <TableColumn fx:id="crtDateColumn" editable="false" maxWidth="110.0" minWidth="110.0" prefWidth="110.0" resizable="false" text="Date" />
                              <TableColumn fx:id="descriptionColumn" editable="false" prefWidth="-1.0" text="Description" />
                              <TableColumn fx:id="marksColumn" editable="false" maxWidth="60.0" minWidth="60.0" prefWidth="60.0" resizable="false" text="Mark" />
                              <TableColumn fx:id="expDateColumn" editable="false" maxWidth="160.0" minWidth="160.0" prefWidth="160.0" resizable="false" text="Exp. Date" />
                              <TableColumn fx:id="statusColumn" editable="false" maxWidth="100.0" minWidth="100.0" prefWidth="100.0" resizable="false" text="Status" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </StackPane>
                  </center>
                  <BorderPane.margin>
                     <Insets />
                  </BorderPane.margin>
                  <padding>
                     <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                  </padding>
               </BorderPane>
            </center>
         </BorderPane>
      </StackPane>
   </center>
</BorderPane>
