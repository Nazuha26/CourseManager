<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.input.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.fxmisc.flowless.*?>
<?import org.fxmisc.richtext.*?>

<BorderPane id="mainPanel" fx:id="mainPanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" stylesheets="@../styles/main_style.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursemanagerfx.controllers.Main_controller">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <!--<fx:include fx:id="titleBarContainer" source="title_bar.fxml" />-->
            <BorderPane fx:id="title_bar" onMouseDragged="#onTitleBarDragged" onMousePressed="#onTitleBarPressed" styleClass="title-bar" stylesheets="@../styles/title_bar_style.css">
               <right>
                  <HBox alignment="CENTER_LEFT" nodeOrientation="RIGHT_TO_LEFT" BorderPane.alignment="CENTER">
                     <children>
                        <Button fx:id="btnClose" layoutX="10.0" layoutY="10.0" onAction="#windowClose" prefHeight="40.0" prefWidth="40.0" styleClass="window-button-close" />
                        <Button fx:id="btnMaximize" onAction="#windowMaximize" prefHeight="40.0" prefWidth="40.0" styleClass="window-button-restore" />
                        <Button fx:id="btnMinimize" onAction="#windowMinimize" prefHeight="40.0" prefWidth="40.0" styleClass="window-button-minimize" />
                     </children>
                  </HBox>
               </right>
               <center>
                  <Label fx:id="lblAppName" styleClass="window-app-name" text="CourseManagerFX" BorderPane.alignment="CENTER">
                     <font>
                        <Font size="15.0" />
                     </font></Label>
               </center>
               <left>
                  <MenuBar stylesheets="@../styles/menu_bar.css" BorderPane.alignment="CENTER">
                     <menus>
                        <Menu mnemonicParsing="false" text="File">
                           <items>
                              <MenuItem fx:id="miNew" mnemonicParsing="false" onAction="#miNew" text="New">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="N" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator>
                              </MenuItem>
                              <MenuItem fx:id="miOpen" mnemonicParsing="false" onAction="#miOpen" text="Open">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="O" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator>
                              </MenuItem>
                              <MenuItem fx:id="miSave" mnemonicParsing="false" onAction="#miSave" text="Save">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="S" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator></MenuItem>
                              <MenuItem fx:id="miExport" mnemonicParsing="false" onAction="#miExport" text="Export">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="E" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator>
                              </MenuItem>
                              <SeparatorMenuItem mnemonicParsing="false" />
                              <MenuItem fx:id="miQuit" mnemonicParsing="false" onAction="#miQuit" styleClass="menu-item-quit" text="Quit">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="Q" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator>
                              </MenuItem>
                           </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Edit">
                           <items>
                              <MenuItem mnemonicParsing="false" onAction="#miUndo" text="Undo">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="Z" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator></MenuItem>
                              <MenuItem mnemonicParsing="false" onAction="#miRedo" text="Redo">
                                 <accelerator>
                                    <KeyCodeCombination alt="UP" code="Z" control="DOWN" meta="UP" shift="DOWN" shortcut="UP" />
                                 </accelerator>
                              </MenuItem>
                              <SeparatorMenuItem mnemonicParsing="false" />
                              <MenuItem mnemonicParsing="false" onAction="#miOptions" text="Options">
                                 <accelerator>
                                    <KeyCodeCombination alt="DOWN" code="O" control="UP" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator>
                              </MenuItem>
                           </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Help">
                           <items>
                              <MenuItem mnemonicParsing="false" onAction="#miAbout" text="About">
                                 <accelerator>
                                    <KeyCodeCombination alt="DOWN" code="A" control="UP" meta="UP" shift="UP" shortcut="UP" />
                                 </accelerator></MenuItem>
                           </items>
                        </Menu>
                     </menus>
                  </MenuBar>
               </left>
            </BorderPane>
             <HBox fx:id="tabHBox" spacing="5.0" styleClass="hbox">
                 <padding>
                     <Insets left="5.0" right="5.0" top="5.0" />
                 </padding>
             </HBox>
         </children>
      </VBox>
