                                                                           <Spinner fx:id="spinnerExpTimeCount" maxHeight="Infinity" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="70.0" styleClass="expired-spinner" HBox.hgrow="ALWAYS" />
